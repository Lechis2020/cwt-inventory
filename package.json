{
  "name": "cwt-inventory",
  "version": "1.0.0",
  "description": "Inventory management app for tracking items, stock levels, and movements",
  "main": "main.js",
  "homepage": "./",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "node web-server.js",
    "desktop": "electron .",
    "dev": "electron . --debug",
    "web": "node web-server.js",
    "build": "electron-builder",
    "build-win": "electron-builder --win --publish never"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.0"
  },
  "dependencies": {
    "exceljs": "^4.3.0"
  },
  "build": {
    "appId": "com.cwt.inventory",
    "productName": "CWT Inventory",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
